            },
            {
              "type": "text",
              "id": "UG37H",
              "name": "s5cl3",
              "fill": "$neon",
              "content": "        .get(\"v1/lines\") { parameter(\"transport_authority_id\", 1) }",
              "fontFamily": "$ff-mono",
              "fontSize": 32,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "mmhTT",
              "name": "s5cl4",
              "fill": "$fg",
              "content": "        .body<List<LinesResponse>>()",
              "fontFamily": "$ff-mono",
              "fontSize": 32,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "cja3l",
              "name": "s5cl5",
              "fill": "$fg",
              "content": "        .firstOrNull()",
              "fontFamily": "$ff-mono",
              "fontSize": 32,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "I3BfPC",
              "name": "s5cl6",
              "fill": "$fg",
              "content": "    DataResult.Success(mapResponseToDomain(response))",
              "fontFamily": "$ff-mono",
              "fontSize": 32,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "itSfH",
              "name": "s5cl7",
              "fill": "$fgMuted",
              "content": "} catch (e: Exception) { DataResult.Error(e.toNetworkError()) }",
