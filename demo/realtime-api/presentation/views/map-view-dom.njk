        'Universitetet':        [1080, 265],
        'Tekniska högskolan':   [1080, 320],
        'Stadion':              [1080, 380],

        // ============== RED — T13 NORTHERN ARM (Ropsten) ==============
        'Östermalmstorg':       [1080, 480],
        'Karlaplan':            [1170, 410],
        'Gärdet':               [1235, 360],
        'Ropsten':              [1310, 280],

        // ============== RED — SHARED SOUTH ==============
        // T-Centralen (940, 480) — central pill
        'Gamla stan':           [940, 530],
        'Slussen':              [940, 575],
        'Mariatorget':          [905, 615],
        'Zinkensdamm':          [840, 635],
        'Hornstull':            [775, 655],
        'Liljeholmen':          [710, 675],

        // ============== RED — T13 SOUTHERN ARM (Norsborg) ==============
        'Aspudden':             [645, 695],
        'Örnsberg':             [580, 715],
        'Axelsberg':            [515, 735],
        'Mälarhöjden':          [455, 770],
        'Bredäng':              [400, 800],
        'Sätra':                [355, 830],
        'Skärholmen':           [310, 855],
        'Vårberg':              [275, 880],
        'Vårby gård':           [240, 905],
        'Masmo':                [205, 925],
        'Fittja':               [170, 945],
        'Alby':                 [140, 960],
        'Hallunda':             [110, 975],
        'Norsborg':             [ 80, 990],

        // ============== RED — T14 SOUTHERN ARM (Fruängen) ==============
        'Midsommarkransen':     [685, 725],
        'Telefonplan':          [665, 770],
        'Hägerstensåsen':       [645, 815],
        'Västertorp':           [625, 860],
        'Fruängen':             [605, 905],

        // ============== GREEN — T19 WESTERN ARM ==============
