        'Högdalen':             [770, 920],
        'Rågsved':              [735, 950],
        'Hagsätra':             [700, 985],

        // T-Centralen as a station for train animation (rendered as pill)
        'T-Centralen':          [940, 480],
    };

    const LINES = {
        T10: {
            color: 'var(--metro-blue)',
            stations: ['Hjulsta', 'Tensta', 'Rinkeby', 'Rissne', 'Duvbo', 'Sundbybergs centrum.', 'Solna strand', 'Huvudsta', 'Västra skogen', 'Stadshagen', 'Fridhemsplan', 'Rådhuset', 'T-Centralen', 'Kungsträdgården'],
        },
        T11: {
            color: 'var(--metro-blue)',
