        'Hässelby strand':      [240, 470],
        'Hässelby gård':        [275, 470],
        'Johannelund':          [305, 470],
        'Vällingby':            [335, 470],
        'Råcksta':              [365, 470],
        'Blackeberg':           [395, 470],
        'Islandstorget':        [425, 470],
        'Ängbyplan':            [455, 470],

        // ============== GREEN — T17/T19 ==============
        'Åkeshov':              [490, 470],
        'Brommaplan':           [520, 470],
        'Abrahamsberg':         [550, 470],
        'Stora mossen':         [580, 470],

        // ============== GREEN — T17/T18/T19 SHARED TRUNK ==============
        'Alvik':                [620, 470],
        'Kristineberg':         [660, 470],
        'Thorildsplan':         [700, 470],
        // Fridhemsplan (765, 470) shared with blue
        'S:t Eriksplan':        [800, 470],
        'Odenplan':             [840, 470],
        'Rådmansgatan':         [880, 470],
        'Hötorget':             [905, 470],
        // T-Centralen (940, 480) — central pill
        // Gamla stan (940, 530) — shared with red
        // Slussen (940, 575) — shared with red

        // ============== GREEN — SHARED SOUTH SPINE ==============
        'Medborgarplatsen':     [940, 615],
        'Skanstull':            [940, 655],
        'Gullmarsplan':         [940, 700],

        // ============== GREEN — T17/T18 to Skärmarbrink ==============
        'Skärmarbrink':         [985, 720],

        // ============== GREEN — T17 EAST ARM (Skarpnäck) ==============
        'Hammarbyhöjden':       [1050, 740],
        'Björkhagen':           [1115, 760],
        'Kärrtorp':             [1180, 775],
        'Bagarmossen':          [1240, 790],
        'Skarpnäck':            [1305, 800],

        // ============== GREEN — T18 SOUTH ARM (Farsta strand) ==============
        'Blåsut':               [985, 760],
        'Sandsborg':            [985, 795],
        'Skogskyrkogården':     [985, 830],
        'Tallkrogen':           [985, 865],
