        'Alvik':                 -45,
        'Kristineberg':          -45,
        'Thorildsplan':          -45,
        // Green city-core trunk
        'S:t Eriksplan':         -45,
        'Odenplan':              -45,
        'Rådmansgatan':          -45,
        'Hötorget':              -45,
        // Red south horizontal
        'Mariatorget':           -45,
        'Zinkensdamm':           -45,
        'Hornstull':             -45,
        'Liljeholmen':           -45,
        'Aspudden':              -45,
        'Örnsberg':              -45,
        'Axelsberg':             -45,
        // Red T13 SW diagonal — keep labels horizontal so the 14 stations
        // packed onto the Norsborg branch stair-step cleanly down the
        // diagonal. -30° projected adjacent labels onto each other because
        // dots are only ~30 px apart along the line; horizontal labels with
        // side: 'right' stay in their own row by virtue of the diagonal.
        // (No rotation entries here — falls back to LABEL_SIDE='right'.)
        // Red T14 SW arm
        'Midsommarkransen':      -45,
        'Telefonplan':           -45,
        'Hägerstensåsen':        -45,
        'Västertorp':            -45,
        // Green T19 SW arm — labels angle the other way
        'Globen':                 30,
        'Enskede gård':           30,
        'Sockenplan':             30,
        'Svedmyra':               30,
        'Stureby':                30,
        'Bandhagen':              30,
        'Högdalen':               30,
        'Rågsved':                30,
        // Green T17 east arm
        'Hammarbyhöjden':        -30,
        'Björkhagen':            -30,
        'Kärrtorp':              -30,
        'Bagarmossen':           -30,
    };

    // Major junctions get white pills with their name in dark text.
    const JUNCTIONS = ['Slussen', 'Gamla stan', 'Fridhemsplan'];

    // ---- Helpers ---------------------------------------------------------
    function svg(tag, attrs = {}, text) {
        const el = document.createElementNS('http://www.w3.org/2000/svg', tag);
        for (const [k, v] of Object.entries(attrs)) el.setAttribute(k, String(v));
        if (text != null) el.textContent = text;
        return el;
    }

    function labelOffset(side) {
        switch (side) {
            case 'right':  return { dx:  10, dy: 4, anchor: 'start' };
            case 'left':   return { dx: -10, dy: 4, anchor: 'end' };
            case 'top':    return { dx:   0, dy: -10, anchor: 'middle' };
            case 'bottom': return { dx:   0, dy: 16, anchor: 'middle' };
        }
        return { dx: 10, dy: 4, anchor: 'start' };
    }

    // ---- Render lines as polylines --------------------------------------
    const linesGroup = document.getElementById('lines');
    for (const [code, line] of Object.entries(LINES)) {
        const pts = line.stations
            .map(name => STATIONS[name])
            .filter(Boolean)
            .map(([x, y]) => `${x},${y}`)
            .join(' ');
        linesGroup.appendChild(svg('polyline', {
            points: pts,
            fill: 'none',
            stroke: line.color,
            'stroke-width': 6,
            'stroke-linecap': 'round',
            'stroke-linejoin': 'round',
            opacity: 0.95,
        }));
    }

    // ---- Render station dots + labels -----------------------------------
    const stationsGroup = document.getElementById('stations');

    // Map each station to the colour of the FIRST line that uses it
    const stationColor = {};
    for (const line of Object.values(LINES)) {
        for (const name of line.stations) {
            if (!stationColor[name]) stationColor[name] = line.color;
        }
    }

    for (const [name, [x, y]] of Object.entries(STATIONS)) {
        if (TERMINI[name] || JUNCTIONS.includes(name) || name === 'T-Centralen') continue;

        const color = stationColor[name] || '#888';
        const dot = svg('circle', {
            cx: x, cy: y, r: 5,
            class: 'station-circle',
            stroke: color,
            'data-station': name,
        });
        stationsGroup.appendChild(dot);

        const side = LABEL_SIDE[name] || 'right';
        const off = labelOffset(side);
        const rot = LABEL_ROTATION[name];
        const labelAttrs = {
            x: x + off.dx,
            y: y + off.dy,
            'text-anchor': off.anchor,
            class: 'station-label',
        };
        if (rot) {
            // Rotate around the station dot itself so the label fans out
            // diagonally without drifting from the line.
            labelAttrs['text-anchor'] = 'start';
            labelAttrs.x = x + 8;
            labelAttrs.y = y + 4;
            labelAttrs.transform = `rotate(${rot} ${x} ${y})`;
        }
        stationsGroup.appendChild(svg('text', labelAttrs, name));
    }

    // ---- Render terminus pills ------------------------------------------
    const terminiGroup = document.getElementById('termini');
    for (const [name, info] of Object.entries(TERMINI)) {
        const pos = STATIONS[name];
        if (!pos) continue;
        const [x, y] = pos;
        const color = LINES[info.code]?.color || '#888';
        const side = info.side;

        // Approximate width of the upper-cased terminus name in pixels.
        // ~9 px per char at the 13 px terminus-name font matches the
        // computed bounding box closely enough for layout.
        const approxNameW = name.length * 9 + 8;
        const pillW = 42, pillH = 22;

        // Layout convention from the official SL map:
        //   side='right' → [dot] [pill] [NAME]   (label reads outward
        //                                         from line tip)
        //   side='left'  → [pill] [NAME] [dot]   (label reads INTO the
        //                                         line tip — used at
        //                                         Hässelby strand etc.
        //                                         where the line CONTINUES
        //                                         past the terminus)
        let pillX, nameX, nameAnchor;
        if (side === 'right') {
            pillX = x + 14;
            nameX = pillX + pillW + 8;
            nameAnchor = 'start';
        } else {
            nameX = x - 14;
            nameAnchor = 'end';
            pillX = nameX - approxNameW - 8 - pillW;
        }
        const pillY = y - pillH / 2;
        const textX = pillX + pillW / 2;

        terminiGroup.appendChild(svg('rect', {
            x: pillX, y: pillY, width: pillW, height: pillH,
            rx: 4, ry: 4,
            fill: color,
            class: 'terminus-pill',
        }));
        terminiGroup.appendChild(svg('text', {
            x: textX, y: pillY + pillH / 2 + 5,
            'text-anchor': 'middle',
            class: 'terminus-text',
        }, info.code));
        terminiGroup.appendChild(svg('text', {
            x: nameX, y: y + 5,
            'text-anchor': nameAnchor,
            class: 'terminus-name',
        }, name));

        // Coloured dot at the line tip
        terminiGroup.appendChild(svg('circle', {
            cx: x, cy: y, r: 6,
            fill: color,
            class: 'station-circle',
            stroke: color,
            'data-station': name,
        }));
    }

    // ---- Render junction (white pill) markers ---------------------------
    const junctionsGroup = document.getElementById('junctions');
    for (const name of JUNCTIONS) {
        const pos = STATIONS[name];
        if (!pos) continue;
        const [x, y] = pos;
        const w = name.length * 7 + 18, h = 18;
        junctionsGroup.appendChild(svg('rect', {
            x: x + 12, y: y - h/2,
            width: w, height: h,
            rx: 9, ry: 9,
            class: 'junction-pill',
        }));
        junctionsGroup.appendChild(svg('text', {
            x: x + 12 + w/2, y: y + 4,
            'text-anchor': 'middle',
            class: 'junction-text',
        }, name));
        // dot
        junctionsGroup.appendChild(svg('circle', {
            cx: x, cy: y, r: 6,
            fill: 'white',
            stroke: '#1a1a1a',
            'stroke-width': 2,
            class: 'station-circle',
            'data-station': name,
        }));
    }

    // ---- Render T-Centralen central pill --------------------------------
    const centralGroup = document.getElementById('central');
    const [tcX, tcY] = STATIONS['T-Centralen'];
    const cw = 110, ch = 28;
    centralGroup.appendChild(svg('rect', {
        x: tcX - cw/2, y: tcY - ch/2,
        width: cw, height: ch,
        rx: 14, ry: 14,
        class: 'central-pill',
    }));
    centralGroup.appendChild(svg('text', {
        x: tcX, y: tcY + 5,
        'text-anchor': 'middle',
        class: 'central-text',
    }, 'T-Centralen'));
    // Hidden circle so the train animation can target T-Centralen too.
    centralGroup.appendChild(svg('circle', {
        cx: tcX, cy: tcY, r: 0,
        class: 'station-circle',
        'data-station': 'T-Centralen',
    }));

    // ---- WebSocket — drive the live train icons --------------------------
    const trainsGroup = document.getElementById('trains');
    const activeTrains = new Map();

    function findStationCircle(name) {
        const norm = name.trim().replace(/\s+/g, ' ');
        return document.querySelector(`[data-station="${cssEscape(norm)}"]`);
    }
    function cssEscape(s) { return s.replace(/(["\\])/g, '\\$1'); }

    const wsProtocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
    const ws = new WebSocket(`${wsProtocol}//${window.location.host}/updates/map`);
    ws.onopen  = () => console.log('Live map WebSocket connected.');
    ws.onerror = (err) => console.error('Live map WebSocket error:', err);
    ws.onclose = () => console.log('Live map WebSocket closed.');

    ws.onmessage = (event) => {
        const msg = JSON.parse(event.data);
        if (msg.type !== 'update') return;
        const station = findStationCircle(msg.currentStop?.name ?? '');
        if (!station) {
            console.warn('Station not on schematic map:', msg.currentStop?.name);
            return;
        }
        const cx = parseFloat(station.getAttribute('cx'));
        const cy = parseFloat(station.getAttribute('cy'));
        let train = activeTrains.get(msg.tripId);
        if (!train) {
            const t = svg('circle', { r: 8, class: 'train' });
            trainsGroup.appendChild(t);
            train = { el: t, lastStation: null };
            activeTrains.set(msg.tripId, train);
        }
        train.el.setAttribute('cx', cx);
        train.el.setAttribute('cy', cy);
        if (train.lastStation) train.lastStation.classList.remove('active');
        station.classList.add('active');
        train.lastStation = station;
    };
</script>
</body>
</html>
