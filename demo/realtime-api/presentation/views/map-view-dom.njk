<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Live Simulation Map</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous"/>
    <style>
        :root {
            --bg: #0A0E12;
            --map-bg: #ffffff;
            --fg: #E8EBEE;
            --fg-muted: #B6BEC8;
            --metro-blue: #007DC4;
            --metro-red: #DC1F1F;
            --metro-green: #00A859;
            --train: #FFB800;
        }

        body {
            background: var(--bg);
            color: var(--fg);
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            margin: 0;
            min-height: 100vh;
        }

        .header {
            text-align: center;
            padding: 28px 24px 8px;
        }

        h1 {
            margin: 0;
            font-size: 26px;
            font-weight: 700;
            letter-spacing: -0.4px;
        }

        .subtitle {
            margin-top: 4px;
            color: var(--fg-muted);
            font-size: 13px;
        }

        .subtitle code {
            background: rgba(255, 255, 255, 0.06);
            padding: 1px 6px;
            border-radius: 3px;
            font-size: 12px;
        }

        .map-wrapper {
            max-width: 1480px;
            margin: 16px auto 80px;
            padding: 16px;
        }

        .map-frame {
            background: var(--map-bg);
            border-radius: 16px;
            padding: 28px 32px;
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5);
        }

        svg.metro {
            width: 100%;
            height: auto;
            display: block;
        }

        .legend {
            display: flex;
            gap: 32px;
            justify-content: center;
            margin-top: 18px;
            flex-wrap: wrap;
        }

        .legend-item {
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--fg-muted);
            font-size: 13px;
        }

        .legend-swatch {
            width: 32px;
            height: 6px;
            border-radius: 3px;
        }

        /* Station circles */
        .station-circle {
            fill: white;
            stroke-width: 2.5;
            transition: r 200ms ease, filter 200ms ease;
        }

        .station-circle.active {
            r: 8;
            filter: drop-shadow(0 0 10px var(--train));
        }

        .station-label {
            fill: #1a1a1a;
            font-size: 11px;
            font-family: 'Helvetica Neue', sans-serif;
            font-weight: 500;
            pointer-events: none;
            user-select: none;
        }

        .terminus-pill {
            stroke: none;
        }

        .terminus-text {
            font-size: 13px;
            font-weight: 800;
            fill: white;
            font-family: 'Helvetica Neue', sans-serif;
        }

        .terminus-name {
            fill: #1a1a1a;
            font-size: 13px;
            font-weight: 800;
            font-family: 'Helvetica Neue', sans-serif;
            text-transform: uppercase;
        }

        .central-pill {
            fill: white;
            stroke: #1a1a1a;
            stroke-width: 2;
        }

        .central-text {
            font-size: 14px;
            font-weight: 800;
            fill: #1a1a1a;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .junction-pill {
            fill: white;
            stroke: #1a1a1a;
            stroke-width: 1.5;
        }

        .junction-text {
            font-size: 11px;
            font-weight: 600;
            fill: #1a1a1a;
        }

        .train {
            fill: var(--train);
            stroke: #1a1a1a;
            stroke-width: 2;
            filter: drop-shadow(0 0 10px var(--train));
            transition: cx 800ms cubic-bezier(0.4, 0, 0.2, 1), cy 800ms cubic-bezier(0.4, 0, 0.2, 1);
        }
    </style>
</head>
<body>
<div class="header">
    <h1>Live Simulation Map</h1>
    <div class="subtitle">Tunnelbanan trains broadcast over <code>WS /updates/map</code> · stations light up as trains arrive</div>
</div>

<div class="map-wrapper">
    <div class="map-frame">
        <svg class="metro" viewBox="0 0 1500 1080" xmlns="http://www.w3.org/2000/svg">
            <g id="lines"></g>
            <g id="stations"></g>
            <g id="termini"></g>
            <g id="junctions"></g>
            <g id="central"></g>
            <g id="trains"></g>
        </svg>

        <div class="legend">
            <div class="legend-item"><div class="legend-swatch" style="background: var(--metro-blue);"></div>Blå linjen · T10, T11</div>
            <div class="legend-item"><div class="legend-swatch" style="background: var(--metro-red);"></div>Röda linjen · T13, T14</div>
            <div class="legend-item"><div class="legend-swatch" style="background: var(--metro-green);"></div>Gröna linjen · T17, T18, T19</div>
            <div class="legend-item"><div class="legend-swatch" style="background: var(--train); border: 1px solid #ccc;"></div>Live train</div>
        </div>
    </div>
</div>

<script>
    // ---------------------------------------------------------------------
    // Schematic Stockholm Tunnelbanan — coordinates picked to mirror the
    // official SL map (https://tunnelbanakarta.com/) topology:
