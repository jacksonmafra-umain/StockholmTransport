    // Termini get a coloured pill with the line code in white + station name to one side.
    // Per-terminus rendering: which line code goes in the pill, and which
    // side of the line tip the [pill][NAME] block extends. The convention
    // matches the official SL map — pill always abuts the line tip, name
    // reads outward into the page (i.e. the dot is at the inner edge of
    // the [pill][NAME] block).
    const TERMINI = {
        // 'left' side termini sit at outer edges of the map where the
        // line continues from the dot inward into the page — Hjulsta,
        // Akalla, Hässelby strand. The label sits 'before' the dot in
        // reading order: [pill][NAME][dot].
        'Hjulsta':              { code: 'T10', side: 'left' },
        'Akalla':               { code: 'T11', side: 'left' },
        'Hässelby strand':      { code: 'T19', side: 'left' },

        // 'right' side termini sit at line ends where the label reads
        // outward from the line tip: [dot][pill][NAME]. This is the
        // common case for the SL map's south / east outer edges.
        'Kungsträdgården':      { code: 'T11', side: 'right' },
        'Mörby centrum':        { code: 'T14', side: 'right' },
        'Ropsten':              { code: 'T13', side: 'right' },
        'Norsborg':             { code: 'T13', side: 'right' },
        'Fruängen':             { code: 'T14', side: 'right' },
