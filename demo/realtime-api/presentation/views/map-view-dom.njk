        },
        T13: {
            color: 'var(--metro-red)',
            stations: ['Norsborg', 'Hallunda', 'Alby', 'Fittja', 'Masmo', 'Vårby gård', 'Vårberg', 'Skärholmen', 'Sätra', 'Bredäng', 'Mälarhöjden', 'Axelsberg', 'Örnsberg', 'Aspudden', 'Liljeholmen', 'Hornstull', 'Zinkensdamm', 'Mariatorget', 'Slussen', 'Gamla stan', 'T-Centralen', 'Östermalmstorg', 'Karlaplan', 'Gärdet', 'Ropsten'],
        },
        T14: {
            color: 'var(--metro-red)',
            stations: ['Fruängen', 'Västertorp', 'Hägerstensåsen', 'Telefonplan', 'Midsommarkransen', 'Liljeholmen', 'Hornstull', 'Zinkensdamm', 'Mariatorget', 'Slussen', 'Gamla stan', 'T-Centralen', 'Östermalmstorg', 'Stadion', 'Tekniska högskolan', 'Universitetet', 'Bergshamra', 'Danderyds sjukhus', 'Mörby centrum'],
        },
        T17: {
            color: 'var(--metro-green)',
            stations: ['Åkeshov', 'Brommaplan', 'Abrahamsberg', 'Stora mossen', 'Alvik', 'Kristineberg', 'Thorildsplan', 'Fridhemsplan', 'S:t Eriksplan', 'Odenplan', 'Rådmansgatan', 'Hötorget', 'T-Centralen', 'Gamla stan', 'Slussen', 'Medborgarplatsen', 'Skanstull', 'Gullmarsplan', 'Skärmarbrink', 'Hammarbyhöjden', 'Björkhagen', 'Kärrtorp', 'Bagarmossen', 'Skarpnäck'],
        },
        T18: {
            color: 'var(--metro-green)',
            stations: ['Alvik', 'Kristineberg', 'Thorildsplan', 'Fridhemsplan', 'S:t Eriksplan', 'Odenplan', 'Rådmansgatan', 'Hötorget', 'T-Centralen', 'Gamla stan', 'Slussen', 'Medborgarplatsen', 'Skanstull', 'Gullmarsplan', 'Skärmarbrink', 'Blåsut', 'Sandsborg', 'Skogskyrkogården', 'Tallkrogen', 'Gubbängen', 'Hökarängen', 'Farsta', 'Farsta strand'],
        },
        T19: {
            color: 'var(--metro-green)',
            stations: ['Hässelby strand', 'Hässelby gård', 'Johannelund', 'Vällingby', 'Råcksta', 'Blackeberg', 'Islandstorget', 'Ängbyplan', 'Åkeshov', 'Brommaplan', 'Abrahamsberg', 'Stora mossen', 'Alvik', 'Kristineberg', 'Thorildsplan', 'Fridhemsplan', 'S:t Eriksplan', 'Odenplan', 'Rådmansgatan', 'Hötorget', 'T-Centralen', 'Gamla stan', 'Slussen', 'Medborgarplatsen', 'Skanstull', 'Gullmarsplan', 'Globen', 'Enskede gård', 'Sockenplan', 'Svedmyra', 'Stureby', 'Bandhagen', 'Högdalen', 'Rågsved', 'Hagsätra'],
        },
    };

    // Per-station label-side overrides — chosen so labels never collide with
    // adjacent lines on the official map's geometry.
    const LABEL_SIDE = {
        // Blue T10 NW arm — labels to the right (lines run NW → SE)
        'Tensta':                'right',
        'Rinkeby':               'right',
        'Rissne':                'right',
        'Duvbo':                 'right',
        'Sundbybergs centrum.':  'right',
        'Solna strand':          'right',
        'Huvudsta':              'right',
        // Blue T11 NW arm
        'Husby':                 'right',
        'Kista':                 'right',
        'Hallonbergen':          'right',
        'Näckrosen':             'right',
        'Solna centrum':         'right',
        'Västra skogen':         'right',
        'Stadshagen':            'right',
        // Blue trunk
        'Rådhuset':              'bottom',
        // Red T14 N arm — labels right
        'Mörby centrum':         'right',
        'Danderyds sjukhus':     'right',
        'Bergshamra':            'right',
        'Universitetet':         'right',
        'Tekniska högskolan':    'right',
        'Stadion':               'right',
        // Red T13 NE arm — labels above
        'Östermalmstorg':        'right',
        'Karlaplan':             'right',
        'Gärdet':                'right',
        // Red south horizontal — labels above (line runs east-west)
        'Mariatorget':           'top',
        'Zinkensdamm':           'top',
        'Hornstull':             'top',
        'Liljeholmen':           'top',
        'Aspudden':              'top',
        'Örnsberg':              'top',
        'Axelsberg':             'top',
        // T13 SW (Norsborg) — labels right (line runs SW)
        'Mälarhöjden':           'right',
        'Bredäng':               'right',
        'Sätra':                 'right',
        'Skärholmen':            'right',
        'Vårberg':               'right',
        'Vårby gård':            'right',
        'Masmo':                 'right',
        'Fittja':                'right',
        'Alby':                  'right',
        'Hallunda':              'right',
        // T14 SW (Fruängen) — labels right
        'Midsommarkransen':      'right',
        'Telefonplan':           'right',
        'Hägerstensåsen':        'right',
        'Västertorp':            'right',
        // Green west horizontal — labels below (so they don't collide with blue arm above)
        'Hässelby gård':         'bottom',
        'Johannelund':           'bottom',
        'Vällingby':             'bottom',
        'Råcksta':               'bottom',
        'Blackeberg':            'bottom',
        'Islandstorget':         'bottom',
        'Ängbyplan':             'bottom',
        'Åkeshov':               'bottom',
        'Brommaplan':            'bottom',
        'Abrahamsberg':          'bottom',
        'Stora mossen':          'bottom',
        'Alvik':                 'bottom',
        'Kristineberg':          'bottom',
        'Thorildsplan':          'bottom',
        // Green city core trunk — labels above so they read like the official
        'S:t Eriksplan':         'top',
        'Odenplan':              'top',
        'Rådmansgatan':          'top',
        'Hötorget':              'top',
        // Green south spine — labels right
        'Medborgarplatsen':      'right',
        'Skanstull':             'right',
        'Gullmarsplan':          'right',
        'Skärmarbrink':          'right',
        // T17 east arm — labels above (line runs east)
        'Hammarbyhöjden':        'top',
        'Björkhagen':            'top',
        'Kärrtorp':              'top',
        'Bagarmossen':           'top',
        // T18 south arm — labels right
        'Blåsut':                'right',
        'Sandsborg':             'right',
        'Skogskyrkogården':      'right',
        'Tallkrogen':            'right',
