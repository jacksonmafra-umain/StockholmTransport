        'Duvbo':                [440, 180],
        'Sundbybergs centrum.':[490, 215],
        'Solna strand':         [555, 260],
        'Huvudsta':             [620, 305],

        // ============== BLUE — T11 NORTHERN ARM ==============
        'Akalla':               [490,  60],
