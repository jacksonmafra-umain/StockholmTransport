    };

    // Per-station label rotation in degrees (counter-clockwise). Used for
    // stations packed along a horizontal trunk where straight horizontal
    // labels would collide ("Hässelby strand · Hässelby gård · Johannelund
    // · …" stacking on top of each other). Convention: -45° tilts the text
    // up-and-right, mirroring how the official SL map angles its labels
    // along the green western trunk and the red south horizontal.
    const LABEL_ROTATION = {
        // Green western trunk
        'Hässelby gård':         -45,
        'Johannelund':           -45,
        'Vällingby':             -45,
        'Råcksta':               -45,
        'Blackeberg':            -45,
        'Islandstorget':         -45,
        'Ängbyplan':             -45,
        'Åkeshov':               -45,
        'Brommaplan':            -45,
