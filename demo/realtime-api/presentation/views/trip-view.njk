<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trip — {{ tripId }}</title>
    <style>
        :root {
            --bg: #0A0E12;
            --surface: #161B21;
            --surface-2: #1F252C;
            --fg: #E8EBEE;
            --fg-muted: #B6BEC8;
            --line: #303942;
            --metro-blue: #0064A8;
            --metro-red: #D71920;
            --metro-green: #00853E;
            --pendeltag: #B25196;
            --tram: #E97713;
            --bus: #D71920;
            --waterway: #008CB4;
            --train: #FFB800;
        }

        * { box-sizing: border-box; }

        body {
            background: var(--bg);
            color: var(--fg);
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            min-height: 100vh;
            margin: 0;
            padding: 0;
        }

        .wrap {
            max-width: 960px;
            margin: 0 auto;
            padding: 48px 24px 96px;
        }

        .header {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 32px;
        }

        .header-puck {
            width: 56px;
            height: 56px;
            border-radius: 50%;
            background: var(--accent, var(--metro-blue));
            display: grid;
            place-items: center;
            color: white;
            font-weight: 900;
            font-size: 20px;
            flex-shrink: 0;
        }

        h1 {
            margin: 0;
            font-size: 24px;
            font-weight: 700;
            letter-spacing: -0.3px;
        }

        .subtitle {
            color: var(--fg-muted);
            font-size: 13px;
            margin-top: 2px;
        }

        .header-meta {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--fg-muted);
            font-size: 13px;
        }

        .live-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--accent, var(--metro-blue));
            animation: pulse 1.4s ease-in-out infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.4; transform: scale(1.4); }
        }

        .step {
            margin-top: 24px;
            padding: 28px;
            background: var(--surface);
            border: 1px solid var(--line);
            border-radius: 16px;
        }

        .step-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 24px;
        }

        .step-number {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: var(--accent, var(--metro-blue));
            color: white;
            display: grid;
            place-items: center;
            font-size: 13px;
            font-weight: 700;
        }

        .step-title {
            font-size: 16px;
            font-weight: 600;
            color: var(--fg);
        }

        .step-summary {
            margin-left: auto;
            color: var(--fg-muted);
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
        }

        /* Big "you are here" card */
        .current-card {
            display: flex;
            align-items: center;
            gap: 24px;
        }

        .current-rail {
            width: 8px;
            height: 96px;
            border-radius: 4px;
            background: var(--accent, var(--metro-blue));
            flex-shrink: 0;
        }

        .current-station-name {
            font-size: 56px;
            font-weight: 900;
            line-height: 1.05;
            letter-spacing: -1.5px;
            color: var(--fg);
        }

        .current-label {
            color: var(--accent, var(--metro-blue));
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 8px;
        }

        /* Station rail (next + final) */
        .station-rail {
            display: flex;
            flex-direction: column;
        }

        .station-row {
            display: flex;
            align-items: flex-start;
            gap: 16px;
            position: relative;
        }

        .rail-track {
            width: 32px;
            display: flex;
            flex-direction: column;
            align-items: center;
            flex-shrink: 0;
        }

        .rail-dot {
            width: 14px;
            height: 14px;
            border-radius: 50%;
            background: var(--surface);
            border: 3px solid var(--accent, var(--metro-blue));
            position: relative;
            z-index: 2;
        }

        .rail-dot.terminus {
            background: var(--accent, var(--metro-blue));
        }

        .rail-line {
            width: 4px;
            flex: 1;
            min-height: 32px;
            background: var(--accent, var(--metro-blue));
        }

        .station-info {
            flex: 1;
            padding-bottom: 22px;
            padding-top: 0;
        }

        .station-info .meta {
            color: var(--accent, var(--metro-blue));
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            margin-bottom: 2px;
        }

        .station-info .name {
            font-size: 22px;
            font-weight: 600;
            color: var(--fg);
            line-height: 1.2;
        }

        .station-info.final .name {
            font-size: 28px;
            font-weight: 800;
        }

        /* Footer status bar */
        .footer-bar {
            margin-top: 32px;
            padding: 18px 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: var(--surface);
            border: 1px solid var(--line);
            border-radius: 12px;
            color: var(--fg-muted);
            font-size: 13px;
        }

        .footer-bar .status {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .footer-bar .clock {
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--fg);
            font-variant-numeric: tabular-nums;
        }

        /* Loading state */
        .placeholder {
            color: var(--fg-muted);
            font-size: 14px;
            padding: 16px 0;
        }

        @media (max-width: 600px) {
            .current-station-name { font-size: 40px; }
            .step { padding: 20px; }
        }
    </style>
</head>
<body>
<div class="wrap">

    <div class="header">
        <div class="header-puck" id="header-puck">{{ lineCode }}</div>
        <div>
            <h1 id="header-title">Loading trip…</h1>
            <div class="subtitle" id="header-subtitle">Tunnelbanan · live trip</div>
        </div>
        <div class="header-meta">
            <div class="live-dot" id="live-dot"></div>
            <span>LIVE</span>
        </div>
    </div>

    <!-- STEP 1: Current station -->
    <section class="step" id="step-current">
        <div class="step-header">
            <div class="step-number">1</div>
            <div class="step-title">You are here</div>
            <div class="step-summary" id="current-summary">—</div>
        </div>
        <div class="current-card">
            <div class="current-rail"></div>
            <div>
                <div class="current-label">Current station</div>
                <div class="current-station-name" id="current-name">…</div>
            </div>
        </div>
    </section>

    <!-- STEP 2: Next stops -->
    <section class="step" id="step-next">
        <div class="step-header">
            <div class="step-number">2</div>
            <div class="step-title">Coming up</div>
            <div class="step-summary" id="next-summary">—</div>
        </div>
        <div class="station-rail" id="next-rail">
            <div class="placeholder">Waiting for trip data…</div>
        </div>
    </section>

    <!-- STEP 3: Final destination -->
    <section class="step" id="step-final">
        <div class="step-header">
            <div class="step-number">3</div>
            <div class="step-title">Final destination</div>
            <div class="step-summary">Terminus</div>
        </div>
        <div class="station-rail">
            <div class="station-row">
                <div class="rail-track">
                    <div class="rail-dot terminus"></div>
                </div>
                <div class="station-info final">
                    <div class="meta">Final stop</div>
                    <div class="name" id="final-name">—</div>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <div class="footer-bar">
        <div class="status">
            <span>● Trip <span id="trip-id-short">{{ tripId }}</span> · welcome onboard</span>
        </div>
        <div class="clock">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="9"></circle>
                <polyline points="12 7 12 12 16 14"></polyline>
            </svg>
            <span id="current-time">--:--</span>
        </div>
    </div>
</div>

<script>
    const tripId = '{{ tripId }}';
    const lineCode = '{{ lineCode }}';
    const lineMode = '{{ lineMode }}';

    // SL line palette — same mapping the line-selection wizard and the
    // realtime-mobile theme use. The accent CSS variable drives every
    // coloured surface on this page (rail, dots, labels, header puck).
    function colorFor(mode, code) {
        const m = (mode || '').toLowerCase();
        const c = (code || '').replace(/^T/i, '').trim();
        if (m === 'metro') {
            if (c === '10' || c === '11') return 'var(--metro-blue)';
            if (c === '13' || c === '14') return 'var(--metro-red)';
            if (c === '17' || c === '18' || c === '19') return 'var(--metro-green)';
            return 'var(--metro-blue)';
        }
        if (m === 'train') return 'var(--pendeltag)';
        if (m === 'tram') return 'var(--tram)';
        if (m === 'bus') return 'var(--bus)';
        if (m === 'ship' || m === 'ferry') return 'var(--waterway)';
        return 'var(--metro-blue)';
    }

    function lineGroupName(mode, code) {
        if ((mode || '').toLowerCase() !== 'metro') return null;
        const c = (code || '').replace(/^T/i, '').trim();
        if (c === '10' || c === '11') return 'Blå linjen';
        if (c === '13' || c === '14') return 'Röda linjen';
        if (c === '17' || c === '18' || c === '19') return 'Gröna linjen';
        return null;
    }

    // Apply the line accent to the page once at boot.
    const accent = colorFor(lineMode, lineCode);
    document.documentElement.style.setProperty('--accent', accent);

    const groupName = lineGroupName(lineMode, lineCode);
    if (groupName) document.getElementById('header-subtitle').textContent = groupName + ' · live trip';

    // Trip ID truncation for the footer
    const tripIdShort = document.getElementById('trip-id-short');
    if (tripIdShort) tripIdShort.textContent = '#' + tripId.slice(-6);

    // --- Clock ---
    function updateClock() {
        const now = new Date();
        const h = String(now.getHours()).padStart(2, '0');
        const m = String(now.getMinutes()).padStart(2, '0');
        const s = String(now.getSeconds()).padStart(2, '0');
        document.getElementById('current-time').textContent = `${h}:${m}:${s}`;
    }
    setInterval(updateClock, 1000);
    updateClock();

    // --- WebSocket — drive the live updates ---
    const wsProtocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
    const ws = new WebSocket(`${wsProtocol}//${window.location.host}/updates/${tripId}`);

    ws.onopen = () => console.log(`WebSocket connected for trip ${tripId}`);
    ws.onerror = (err) => console.error('WebSocket error', err);
    ws.onclose = () => {
        console.log('WebSocket closed.');
        const dot = document.getElementById('live-dot');
        if (dot) dot.style.background = 'var(--fg-muted)';
    };

    ws.onmessage = (event) => {
        const msg = JSON.parse(event.data);
        if (msg.type !== 'update' || msg.tripId !== tripId) return;

        // Update header
        document.getElementById('header-title').textContent = `${groupName || 'Tunnelbanan'} · to ${msg.finalDestination?.name ?? '—'}`;
        document.getElementById('current-summary').textContent = msg.currentStop?.name ?? '—';
        document.getElementById('next-summary').textContent = `${msg.nextThreeStops.length} upcoming`;

        // Step 1 — current station
        document.getElementById('current-name').textContent = msg.currentStop?.name ?? '—';

        // Step 2 — coming up rail
        const rail = document.getElementById('next-rail');
        rail.innerHTML = '';
        msg.nextThreeStops.forEach((stop, idx) => {
            const row = document.createElement('div');
            row.className = 'station-row';
            row.innerHTML = `
                <div class="rail-track">
                    <div class="rail-dot"></div>
                    ${idx < msg.nextThreeStops.length - 1 ? '<div class="rail-line"></div>' : ''}
                </div>
                <div class="station-info">
                    <div class="meta">Next ${idx + 1}</div>
                    <div class="name">${escapeHtml(stop.name)}</div>
                </div>
            `;
            rail.appendChild(row);
        });
        if (!msg.nextThreeStops.length) {
            rail.innerHTML = '<div class="placeholder">Approaching the terminus…</div>';
        }

        // Step 3 — final destination
        document.getElementById('final-name').textContent = msg.finalDestination?.name ?? '—';
    };

    function escapeHtml(s) {
        return String(s ?? '').replace(/[&<>"']/g, c => ({
            '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
        })[c]);
    }
</script>
</body>
</html>
