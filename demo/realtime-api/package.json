{
  "name": "stockholm-transport-realtime-api",
  "version": "1.0.0",
  "description": "Realtime simulation backend (Express + WebSocket + MongoDB) feeding the stockholm-transport KMP library's realtime module.",
  "type": "module",
  "main": "presentation/server.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "nodemon --watch presentation --watch application --watch domain --watch infrastructure --watch config --ext js,json,njk --exec \"node presentation/server.js\"",
    "start": "node presentation/server.js",
    "bootstrap": "node scripts/bootstrap.js",
    "docker:start": "node scripts/bootstrap.js && npm run dev",
    "seed": "node scripts/seed-from-trafiklab.js --data ./",
    "seed:routes": "node scripts/seed-routes-to-lines.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "geolib": "^3.3.14",
    "merge-deep": "^3.0.3",
    "mongoose": "^9.6.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nunjucks": "^3.2.4",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
